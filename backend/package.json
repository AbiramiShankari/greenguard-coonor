{
  "name": "greenguard-backend",
  "version": "1.0.0",
  "description": "GreenGuard — Civic Waste Management API for Tamil Nadu",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "seed": "node seed.js",
    "db:migrate": "npx prisma migrate dev --name init",
