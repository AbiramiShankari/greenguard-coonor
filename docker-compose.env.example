# Root-level env file for Docker Compose
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/greenguard?schema=public
JWT_SECRET=replace_with_a_strong_random_secret
JWT_REFRESH_SECRET=replace_with_another_strong_random_secret
FRONTEND_URL=http://localhost:5173
SMS_PROVIDER=mock
FAST2SMS_API_KEY=replace_with_fast2sms_api_key
TWILIO_ACCOUNT_SID=replace_with_twilio_sid
TWILIO_AUTH_TOKEN=replace_with_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
ADMIN_PHONE=+91xxxxxxxxxx
GEMINI_API_KEY=replace_with_gemini_api_key
CLOUDINARY_CLOUD_NAME=replace_with_cloudinary_cloud_name
CLOUDINARY_API_KEY=replace_with_cloudinary_api_key
CLOUDINARY_API_SECRET=replace_with_cloudinary_api_secret
EMAIL_USER=replace_with_email_user
EMAIL_PASS=replace_with_email_password
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=greenguard
